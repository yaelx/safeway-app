generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  binaryTargets = ["native", "debian-openssl-3.0.x"] 
  // Ensures Prisma includes the correct engine binary to talk to the database from inside the GCcontainer.
}

datasource db {
  provider = "postgresql"
}

model Shelter {
  id         Int     @id @default(autoincrement())
  name       String
  lat        Float
  lng        Float
  address    String
  type       String
  isOfficial Boolean @default(true)
  city       String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([lat, lng], name: "lat_lng") 
  @@index([lat, lng])
  @@map("shelters")
}

model ShelterReport {
  id        Int      @id @default(autoincrement())
  shelterId Int
  reason    String   // e.g., "wrong_location", "missing", "closed"
  comment   String
  createdAt DateTime @default(now()) @map("created_at")
  city      String?

  @@map("shelter_reports")
}