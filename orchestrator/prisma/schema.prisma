generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Shelter {
  id         Int     @id @default(autoincrement())
  name       String
  lat        Float
  lng        Float
  address    String?
  type       String?
  isOfficial Boolean @default(true)
  city       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ShelterReport {
  id        Int      @id @default(autoincrement())
  shelterId Int
  reason    String   // e.g., "wrong_location", "missing", "closed"
  comment   String?
  createdAt DateTime @default(now())
  city      String?
}