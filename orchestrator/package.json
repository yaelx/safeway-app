{
  "name": "orchestrator",
  "version": "1.0.0",
  "type": "module",
  "description": "Node.js Express logic orchestrator",
  "main": "server.ts",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "inspect-osrm": "ts-node src/inspect-osrm.ts",
