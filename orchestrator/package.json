    "load-coords": "ts-node src/data_load/location_resolver.ts"
  },
  "dependencies": {
    "@mapbox/polyline": "^1.2.1",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@upstash/redis": "^1.37.0",
    "ably": "^2.21.0",
    "axios": "^1.6.8",
    "cors": "^2.8.6",
    "csv-parse": "^6.2.1",
    "csv-parser": "^3.2.0",
    "csv-stringify": "^6.7.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.2",
    "google-auth-library": "^10.6.2",
    "handlebars": "^4.7.9",
    "helmet": "^8.1.0",
    "install": "^0.13.0",
    "kafkajs": "^2.2.4",
    "node-fetch": "^3.3.2",
    "nodemailer": "^8.0.4",
    "npm": "^11.12.1",
    "pg": "^8.20.0",
    "redis": "^5.11.0",
    "sharp": "^0.34.5",
    "uuid": "^11.1.0",
    "xss": "^1.0.15",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/mapbox__polyline": "^1.0.5",
    "@types/node": "^20.12.7",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.18.0",
    "prisma": "^7.5.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.5"
