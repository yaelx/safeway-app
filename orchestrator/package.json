{
  "name": "orchestrator",
  "version": "1.0.0",
  "description": "Node.js Express logic orchestrator",
  "main": "server.ts",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only server.ts",
    "start": "ts-node server.ts",
    "build": "prisma generate && tsc",
  "install": "npm install"
  },
  "dependencies": {
    "@mapbox/polyline": "^1.2.1",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "axios": "^1.6.8",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/mapbox__polyline": "^1.0.5",
    "@types/node": "^20.12.7",
    "@types/pg": "^8.18.0",
    "prisma": "^7.5.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.5"
  }
}
