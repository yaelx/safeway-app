{
  "version": 2,
  "rewrites": [
{
      "source": "/api/(.*)",
      "destination": "/api/index.ts" 
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/frontend/dist/$1"
    }
  ],
  "functions": {
    "api/**/*.ts": { "runtime": "none" }
  },
  "installCommand": "cd frontend && npm install",
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist"
}