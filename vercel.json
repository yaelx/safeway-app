{
  "version": 2,
  "functions": {
    "orchestrator/server.ts": {
      "runtime": "@vercel/node"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/orchestrator/server.ts"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/frontend/dist/$1"
    }
  ]
}