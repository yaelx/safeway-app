{
  "version": 2,
  "builds": [
    {
      "src": "orchestrator/server.ts",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "frontend/dist" }
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "orchestrator/server.ts" },
    { "source": "/(.*)", "destination": "/$1" }
  ]
}