{
  "name": "safeway-app",
  "engines": {
  "node": "22.x"
},
  "private": true,
  "workspaces": [
    "frontend",
    "orchestrator"
  ],
  "scripts": {
    "build": "npm run build --workspace=frontend",
    "dev": "concurrently \"npm run dev --workspace=frontend\" \"npm run dev --workspace=orchestrator\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
