{
  "name": "safeway-app",
  "private": true,
  "workspaces": [
    "frontend",
    "orchestrator",
    "logic-server"
  ],
  "scripts": {
    "start": "concurrently \"npm run start:frontend\" \"npm run start:orchestrator\" \"npm run start:logic\"",
    "start:frontend": "cd frontend && npm run dev",
    "start:orchestrator": "cd orchestrator && npm run dev",
    "start:logic": "cd logic-server && ./venv/bin/uvicorn solver:app --reload --port 8000"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9"
  }
}
